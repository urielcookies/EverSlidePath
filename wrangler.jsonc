{
  "name": "pathshare",
  "main": "./src/worker.ts",
  "compatibility_date": "2024-11-01",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "r2_buckets": [
    {
      "binding": "BUCKET",
      "bucket_name": "pathshare-assets"
    }
  ],
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "pathshare-db",
      "database_id": "cc96adee-f03a-49a3-a6bc-c39171cb9ad3"
    }
  ],
  "assets": {
    "directory": "./dist/client",
    "binding": "STATIC_ASSETS"
  }
}
